# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# Notifications extension: sibling of Runner.
# DO NOT declare pod 'Firebase/Messaging' here — doing so causes CocoaPods to
# create a SECOND GoogleUtilities pod target (with a different hash suffix, e.g.
# GoogleUtilities-54d832b6 vs GoogleUtilities-7cacef58) that produces an
# identically-named GoogleUtilities.framework at the same archive output path,
# triggering Xcode 16 "Multiple commands produce" during archive.
#
# Instead the extension inherits Runner's pod search paths (FRAMEWORK_SEARCH_PATHS
# / HEADER_SEARCH_PATHS) via `inherit! :search_paths`, and the post_install hook
# below injects the required OTHER_LDFLAGS into the generated xcconfig files so
# the extension can link against FirebaseMessaging from Runner's build products.
target 'notifications' do
  use_frameworks!
  inherit! :search_paths
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Fix CreateUniversalBinary failure on Apple Silicon Macs:
      # simulator only needs arm64, not a fat arm64+x86_64 binary.
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES' if config.name == 'Debug'
    end

    if target.name == 'notifications'
      target.build_configurations.each do |config|
        config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'YES'
        config.build_settings['LD_RUNPATH_SEARCH_PATHS'] = '$(inherited) @executable_path/../../Frameworks'
      end
    end
  end

  # Fix: Inject FirebaseMessaging linker flags into the notifications xcconfig files.
  # Because we do NOT declare `pod 'Firebase/Messaging'` for the notifications target
  # (to avoid a duplicate GoogleUtilities pod target), CocoaPods does not generate
  # OTHER_LDFLAGS for that target. We patch the generated xcconfig files directly
  # so the extension can link against FirebaseMessaging (and its transitive deps)
  # that Runner already builds and embeds in Runner.app/Frameworks.
  # The extension finds all frameworks at runtime via @executable_path/../../Frameworks.
  begin
    firebase_ldflags = [
      '-lsqlite3', '-lz',
      '-framework "CoreTelephony"',
      '-framework "FBLPromises"',
      '-framework "FirebaseCore"',
      '-framework "FirebaseCoreInternal"',
      '-framework "FirebaseInstallations"',
      '-framework "FirebaseMessaging"',
      '-framework "Foundation"',
      '-framework "GoogleDataTransport"',
      '-framework "GoogleUtilities"',
      '-framework "Security"',
      '-framework "SystemConfiguration"',
      '-framework "UIKit"',
      '-framework "nanopb"',
      '-weak_framework "UserNotifications"',
    ].join(' ')

    pods_root = installer.sandbox.root.to_s
    %w[Debug Profile Release].each do |cfg|
      xcconfig_path = "#{pods_root}/Target Support Files/Pods-notifications/Pods-notifications.#{cfg.downcase}.xcconfig"
      next unless File.exist?(xcconfig_path)
      content = File.read(xcconfig_path)
      unless content.include?('firebase_ldflags_injected')
        content += "\n# firebase_ldflags_injected\nOTHER_LDFLAGS = $(inherited) #{firebase_ldflags}\n"
        File.write(xcconfig_path, content)
        puts "[fix] Injected FirebaseMessaging ldflags into Pods-notifications.#{cfg.downcase}.xcconfig"
      end
    end
  rescue => e
    puts "Warning: xcconfig ldflags injection failed: #{e.message}"
  end
end