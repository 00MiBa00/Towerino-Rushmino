# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

target 'notifications' do
  use_frameworks!
  inherit! :search_paths
  pod 'Firebase/Messaging'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['GCC_WARN_ABOUT_DEPRECATED_FUNCTIONS'] = 'NO'
    end

    if target.name == 'notifications'
      target.build_configurations.each do |config|
        config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'YES'
        config.build_settings['LD_RUNPATH_SEARCH_PATHS'] = '$(inherited) @executable_path/../../Frameworks'
      end
    end
  end

  # Fix "Multiple commands produce GoogleUtilities.framework" during Xcode archive.
  #
  # When pod 'Firebase/Messaging' is declared in the notifications extension target,
  # CocoaPods creates a second GoogleUtilities pod target with a different hash suffix
  # (e.g. GoogleUtilities-54d832b6 alongside GoogleUtilities-7cacef58 for Runner).
  # Both are dynamic frameworks named GoogleUtilities.framework. During archive, Xcode
  # stages framework outputs in UninstalledProducts — both write to the same path and
  # fail with "Multiple commands produce".
  #
  # Fix: set SKIP_INSTALL=YES on any framework target that produces the same product
  # filename as one of Runner's direct pod dependencies. The duplicate (extension-only)
  # target is still compiled and linked but not staged separately during archive.
  begin
    runner_agg = installer.pods_project.targets.find { |t| t.name == 'Pods-Runner' }
    runner_dep_names = Set.new(
      runner_agg&.dependencies&.map { |d| d.target&.name }&.compact
    )

    # Map product filename → canonical target name for Runner's deps
    runner_products = {}
    runner_dep_names.each do |dep_name|
      dep_target = installer.pods_project.native_targets.find { |t| t.name == dep_name }
      fw_path = dep_target&.product_reference&.path
      runner_products[fw_path] = dep_name if fw_path
    end

    installer.pods_project.native_targets.each do |target|
      next if runner_dep_names.include?(target.name)
      fw_path = target.product_reference&.path
      next unless fw_path && runner_products.key?(fw_path)

      target.build_configurations.each do |config|
        config.build_settings['SKIP_INSTALL'] = 'YES'
      end
      puts "[fix] SKIP_INSTALL=YES on '#{target.name}' (duplicate of '#{runner_products[fw_path]}')"
    end

    installer.pods_project.save
  rescue => e
    puts "Warning: SKIP_INSTALL fix failed: #{e.message}"
  end
end