# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

target 'notifications' do
  use_frameworks!
  inherit! :search_paths
  pod 'Firebase/Messaging'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['GCC_WARN_ABOUT_DEPRECATED_FUNCTIONS'] = 'NO'
    end

    if target.name == 'notifications'
      target.build_configurations.each do |config|
        config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'YES'
        config.build_settings['LD_RUNPATH_SEARCH_PATHS'] = '$(inherited) @executable_path/../../Frameworks'
      end
    end
  end

  # Fix "Multiple commands produce GoogleUtilities.framework/GoogleUtilities_Privacy.bundle"
  # during Xcode archive.
  #
  # Both Pods-Runner and Pods-notifications pull in GoogleUtilities, but CocoaPods creates
  # two separate targets with different hash suffixes (different subspec combinations):
  #   GoogleUtilities-7cacef58 → used by Pods-Runner (via FirebaseAnalytics etc.)
  #   GoogleUtilities-54d832b6 → used by Pods-notifications (via FirebaseMessaging etc.)
  # Both produce GoogleUtilities.framework and GoogleUtilities_Privacy.bundle to the same
  # archive staging path → "Multiple commands produce" error.
  #
  # Fix: set SKIP_INSTALL=YES on any pod target that:
  #   1. Is a direct dependency of Pods-notifications, AND
  #   2. Is NOT a direct dependency of Pods-Runner
  # plus any resource-bundle sub-targets they own.
  # The target still compiles (notifications links against it) but Xcode won't stage
  # it to UninstalledProducts during archive, eliminating the collision.
  begin
    require 'set'

    runner_agg = installer.pods_project.targets.find { |t| t.name == 'Pods-Runner' }
    notif_agg  = installer.pods_project.targets.find { |t| t.name == 'Pods-notifications' }

    runner_direct = Set.new(runner_agg&.dependencies&.map { |d| d.target&.name }&.compact)
    notif_direct  = Set.new(notif_agg&.dependencies&.map  { |d| d.target&.name }&.compact)

    # Targets owned exclusively by notifications (not needed by Runner directly)
    notif_only = notif_direct - runner_direct

    # Also collect resource-bundle sub-targets of notif_only targets
    notif_only_bundles = Set.new
    installer.pods_project.native_targets.each do |t|
      fw = t.product_reference&.path
      next unless fw&.end_with?('.bundle')
      # Bundle belongs to a notif_only parent if its name starts with parent prefix
      notif_only.any? { |parent| t.name.start_with?(parent) } &&
        notif_only_bundles.add(t.name)
    end

    skip_targets = notif_only + notif_only_bundles
    changed = false

    installer.pods_project.native_targets.each do |t|
      next unless skip_targets.include?(t.name)
      t.build_configurations.each { |c| c.build_settings['SKIP_INSTALL'] = 'YES' }
      puts "[fix] SKIP_INSTALL=YES on '#{t.name}'"
      changed = true
    end

    installer.pods_project.save if changed
  rescue => e
    puts "Warning: SKIP_INSTALL fix failed: #{e.message}"
  end
end